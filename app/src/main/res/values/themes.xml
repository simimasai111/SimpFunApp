<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.SimpFun" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="colorOnBackground">@color/text</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text</item>
        <item name="bottomNavigationStyle">@style/Widget.SimpFun.BottomNav</item>
        <item name="materialButtonStyle">@style/Widget.SimpFun.Button</item>
    </style>

    <style name="Widget.SimpFun.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/surface</item>
        <item name="itemIconTint">@color/primary</item>
        <item name="itemTextColor">@color/primary</item>
    </style>

    <style name="Widget.SimpFun.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:layout_height">48dp</item>
    </style>
</resources>
